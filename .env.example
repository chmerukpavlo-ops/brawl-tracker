# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Brawl Stars API Bearer Token
# Отримайте свій токен на https://developer.brawlstars.com/
BRAWL_STARS_API_TOKEN="YOUR_BRAWL_STARS_API_TOKEN"

# Порт для сервера (за замовчуванням 3000)
PORT="3000"

# ─── Sentry / observability (всі — опційні) ────────────────────────
# Якщо VITE_SENTRY_DSN не задано → SDK не вантажиться, app працює без
# моніторингу. Якщо задано — користувачу однаково треба натиснути
# "Дозволити" у consent banner перед першим event-ом.
VITE_SENTRY_DSN=""
# Версія, яку Sentry прив'язує до events (для group-by-release).
# Бажано читати з package.json у CI: `--define VITE_APP_VERSION=$(...)`.
VITE_APP_VERSION=""

# Backend Sentry — окремий project (server-side stack traces ≠
# client-side). Якщо порожній → server.ts не ініціалізує SDK.
SENTRY_DSN_BACKEND=""
SENTRY_TRACES_SAMPLE_RATE="0.1"

# Build-time only (НЕ публічні; НЕ commit-ити в git):
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT="brawl-tracker"

# ─── Product analytics (опційно, опт-ін) ───────────────────────────
# Privacy-first, cookieless. Adapter завантажується ТІЛЬКИ після того,
# як користувач натиснув "Дозволити" у consent banner.
#
# Залиш пустим → noop adapter, 0 KB у бандлі, нічого не відправляється.
# Виборі бекенду:
#   • plausible — простий, $9/міс або self-host
#   • umami     — open source, self-host docker-compose
#   • posthog   — feature-rich, free до 1M events/міс
VITE_ANALYTICS_BACKEND=""

# Plausible
VITE_PLAUSIBLE_DOMAIN=""
VITE_PLAUSIBLE_HOST="https://plausible.io"

# Umami (self-host: docker-compose recipe у ANALYTICS.md)
VITE_UMAMI_WEBSITE_ID=""
VITE_UMAMI_HOST=""

# PostHog (HTTP-only — посилаємо у /capture/ напряму, без `posthog-js`)
VITE_POSTHOG_KEY=""
VITE_POSTHOG_HOST="https://us.i.posthog.com"
