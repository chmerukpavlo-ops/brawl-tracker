{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "icons": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test:run && npm run test:e2e",
    "ci:local": "npm run typecheck && npm run test:run && npm run build",
    "analyze": "ANALYZE=true vite build && open dist/stats.html || true",
    "audit": "npx --yes lighthouse http://localhost:5173 --quiet --chrome-flags='--headless' --output=html --output-path=./lighthouse-report.html --preset=desktop --only-categories=performance,accessibility,best-practices,pwa,seo",
    "sentry:sourcemaps": "npx --yes @sentry/cli sourcemaps inject ./dist && npx --yes @sentry/cli sourcemaps upload --org=$SENTRY_ORG --project=$SENTRY_PROJECT --release=$VITE_APP_VERSION ./dist",
    "release": "npm run build && [ -n \"$SENTRY_AUTH_TOKEN\" ] && npm run sentry:sourcemaps || echo '[release] SENTRY_AUTH_TOKEN not set, skipping source map upload'",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@sentry/node": "^10.55.0",
    "@sentry/react": "^10.55.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "focus-trap-react": "^12.0.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "workbox-window": "^7.4.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@axe-core/react": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "^10.4.1",
    "@storybook/addon-docs": "^10.4.1",
    "@storybook/addon-themes": "^10.4.1",
    "@storybook/react-vite": "^10.4.1",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.7",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "happy-dom": "^20.9.0",
    "msw": "^2.14.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "^10.4.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0"
  }
}
